{
  "name": "trainmap",
  "private": true,
  "version": "0.1.0",
  "description": "Self-hosted personal railway footprint platform.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace trainmap-web",
    "lint": "npm run lint --workspaces --if-present",
    "test": "vitest run",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "db:migrate": "node scripts/run-migrations.mjs db/migrations",
    "db:migrate:initial": "node scripts/run-sql.mjs db/migrations/001_initial.sql",
    "db:migrate:exports": "node scripts/run-sql.mjs db/migrations/002_export_error_message.sql",
    "db:seed": "node scripts/run-sql.mjs db/seeds/demo.sql",
    "playwright:install": "npx playwright install chromium"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "@types/geojson": "^7946.0.14",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.23",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.11.0",
    "npm": ">=10.0.0"
  }
}
